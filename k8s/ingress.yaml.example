# Opsiyonel: cluster disindan erisim icin Ingress ornegi.
# Bunu kullanmadan once kendi domain'in ve TLS secret'in ile uyarla.
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: sgb-api-bridge
  namespace: sgb-api-bridge
  annotations:
    # nginx-ingress kullaniyorsan:
    nginx.ingress.kubernetes.io/proxy-body-size: "0"
    # cert-manager varsa:
    # cert-manager.io/cluster-issuer: letsencrypt-prod
spec:
  ingressClassName: nginx
  rules:
    # Klasik feed host (TXT listeleri + SIEM Pack)
    - host: sgb-feed.kurum.local
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: sgb-api-bridge
                port:
                  number: 80
    # TAXII 2.1 endpoint — istege bagli ayri host. Ayni Service'i kullanir;
    # nginx /taxii2/ ve /api/ rotalari docs/taxii/ altini serve eder. Boyle
    # ayri host SIEM client'larinda TAXII server URL'sini sade tutmak icin
    # pratik (root path = api root). Tek host kullanmak istersen bu blogu sil.
    - host: sgb-taxii.kurum.local
      http:
        paths:
          - path: /taxii2
            pathType: Prefix
            backend:
              service:
                name: sgb-api-bridge
                port:
                  number: 80
          - path: /api
            pathType: Prefix
            backend:
              service:
                name: sgb-api-bridge
                port:
                  number: 80
  # tls:
  #   - hosts: ["sgb-feed.kurum.local", "sgb-taxii.kurum.local"]
  #     secretName: sgb-api-bridge-tls
